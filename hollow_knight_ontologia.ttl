# ==========================================
# 4. RELAÇÕES DE COMÉRCIO (hk:vende)
# ==========================================
hk:Iselda hk:vende hk:WaywardCompass, hk:SimpleKey .

hk:Sly hk:vende hk:GatheringSwarm, hk:StalwartShell, hk:HeavyBlow, hk:Sprintmaster,
    hk:Longnail, hk:LifebloodCore, hk:RancidEgg, hk:LanternDelicateFlower .

hk:Salubra hk:vende hk:ShamanStone, hk:QuickFocus, hk:LifebloodHeart, hk:SteadyBody .

hk:LegEater hk:vende hk:FragileHeart, hk:FragileGreed, hk:FragileStrength,
    hk:UnbreakableHeart, hk:UnbreakableGreed, hk:UnbreakableStrength .

hk:Nailsmith hk:vende hk:SharpenedNail, hk:ChanneledNail, hk:CoiledNail, hk:PureNail .

hk:Seer hk:vende hk:DreamWielder, hk:Dashmaster, hk:Grubsong, hk:DeepFocus .

hk:Lemm hk:vende hk:WanderersJournal, hk:HallownestSeal, hk:KingsIdol, hk:ArcaneEgg .

hk:Grubfather hk:vende hk:GatheringSwarm .

# Relações inversas explícitas (equivalem a hk:vende, mas na direção Item -> NPC)
hk:WaywardCompass hk:compradoDe hk:Iselda .
hk:SharpenedNail hk:compradoDe hk:Nailsmith .

# ==========================================
# 5. HABILIDADES CONCEDIDAS POR ITENS (hk:concede)
# ==========================================
hk:PureNail hk:concede hk:GreatSlash, hk:CycloneSlash, hk:DashSlash .
hk:DreamNail hk:concede hk:AwokenDreamNail .

