@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix hk: <http://example.org/hollowknight#> .

hk:HollowKnightOntology a owl:Ontology ;
    rdfs:label "Ontologia de Hollow Knight"  ;
    rdfs:comment "Ontologia expandida sobre o universo do jogo Hollow Knight (Team Cherry), cobrindo personagens, localidades, itens e suas relações, incluindo comércio com NPCs vendedores." .

# ==========================================
# 1. CLASSES E HIERARQUIA
# ==========================================
hk:Entidade a owl:Class ; rdfs:label "Entidade" .

hk:Personagem a owl:Class ; rdfs:subClassOf hk:Entidade ; rdfs:label "Personagem" .
hk:Localidade a owl:Class ; rdfs:subClassOf hk:Entidade ; rdfs:label "Localidade" .
hk:Item a owl:Class ; rdfs:subClassOf hk:Entidade ; rdfs:label "Item" .

hk:Boss a owl:Class ; rdfs:subClassOf hk:Personagem ; rdfs:label "Chefe" .
hk:NPC a owl:Class ; rdfs:subClassOf hk:Personagem ; rdfs:label "NPC" .
hk:InimigoComum a owl:Class ; rdfs:subClassOf hk:Personagem ; rdfs:label "Inimigo Comum" .
hk:Vendedor a owl:Class ; rdfs:subClassOf hk:NPC ; rdfs:label "Vendedor" ;
    rdfs:comment "NPC que possui pelo menos um item à venda via hk:vende." .

hk:Regiao a owl:Class ; rdfs:subClassOf hk:Localidade ; rdfs:label "Região" .
hk:SubRegiao a owl:Class ; rdfs:subClassOf hk:Localidade ; rdfs:label "Sub-região" .

hk:Amuleto a owl:Class ; rdfs:subClassOf hk:Item ; rdfs:label "Amuleto" .
hk:Habilidade a owl:Class ; rdfs:subClassOf hk:Item ; rdfs:label "Habilidade" .
hk:Equipamento a owl:Class ; rdfs:subClassOf hk:Item ; rdfs:label "Equipamento" .
hk:Chave a owl:Class ; rdfs:subClassOf hk:Equipamento ; rdfs:label "Chave" .
hk:Relíquia a owl:Class ; rdfs:subClassOf hk:Item ; rdfs:label "Relíquia" .
hk:ArteDeUnha a owl:Class ; rdfs:subClassOf hk:Habilidade ; rdfs:label "Arte de Unha" .

# OWL DisjointClasses
hk:Personagem owl:disjointWith hk:Localidade .
hk:Personagem owl:disjointWith hk:Item .
hk:Localidade owl:disjointWith hk:Item .

# ==========================================
# 2. PROPRIEDADES
# ==========================================
hk:habitaEm a owl:ObjectProperty ;
    rdfs:domain hk:Personagem ;
    rdfs:range hk:Localidade ;
    rdfs:label "habita em" .

hk:vende a owl:ObjectProperty ;
    rdfs:domain hk:NPC ;
    rdfs:range hk:Item ;
    rdfs:label "vende" .

hk:compradoDe a owl:ObjectProperty ;
    owl:inverseOf hk:vende ;
    rdfs:domain hk:Item ;
    rdfs:range hk:NPC ;
    rdfs:label "comprado de" .

hk:concede a owl:ObjectProperty ;
    rdfs:domain hk:Item ;
    rdfs:range hk:Habilidade ;
    rdfs:label "concede" .

hk:localizadoEm a owl:ObjectProperty, owl:TransitiveProperty ;
    rdfs:domain hk:Localidade ;
    rdfs:range hk:Localidade ;
    rdfs:label "localizado em" .

hk:fazFronteiraCom a owl:ObjectProperty, owl:SymmetricProperty ;
    rdfs:domain hk:Regiao ;
    rdfs:range hk:Regiao ;
    rdfs:label "faz fronteira com" .

# Propriedade genérica (inversa de habitaEm)
hk:temResidente a owl:ObjectProperty ;
    owl:inverseOf hk:habitaEm ;
    rdfs:domain hk:Localidade ;
    rdfs:range hk:Personagem ;
    rdfs:label "tem residente" .

# Propriedade específica para Chefões (independente, sem inverseOf)
hk:temChefe a owl:ObjectProperty ;
    rdfs:domain hk:Localidade ;
    rdfs:range hk:Boss ;
    rdfs:label "tem chefe" .

hk:nome a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:domain hk:Entidade ;
    rdfs:range xsd:string ;
    rdfs:label "nome" .

hk:custoGeo a owl:DatatypeProperty ;
    rdfs:domain hk:Item ;
    rdfs:range xsd:integer ;
    rdfs:label "custo em Geo" .

hk:espacosAmuleto a owl:DatatypeProperty ;
    rdfs:domain hk:Amuleto ;
    rdfs:range xsd:integer ;
    rdfs:label "espaços de amuleto (notch)" .

hk:vidaMaxima a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:domain hk:Boss ;
    rdfs:range xsd:integer ;
    rdfs:label "vida máxima (HP)" .

hk:dlc a owl:DatatypeProperty ;
    rdfs:domain hk:Entidade ;
    rdfs:range xsd:string ;
    rdfs:label "pacote de expansão (DLC)" .

# ==========================================
# 3. INSTÂNCIAS
# ==========================================

# --- Todas as Regiões Principais ---
hk:Hallownest a hk:Regiao ; hk:nome "Hallownest" .
hk:Dirtmouth a hk:Regiao ; hk:nome "Dirtmouth" ; hk:fazFronteiraCom hk:ForgottenCrossroads, hk:HowlingCliffs .
hk:ForgottenCrossroads a hk:Regiao ; hk:nome "Forgotten Crossroads" ; hk:fazFronteiraCom hk:Greenpath, hk:FungalWastes, hk:CrystalPeak, hk:RestingGrounds .
